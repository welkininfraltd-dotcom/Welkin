# Google Service Account credentials JSON file path
GOOGLE_CREDENTIALS_PATH=credentials.json

# Google Spreadsheet ID (from the sheet URL)
SPREADSHEET_ID=your_spreadsheet_id_here

# Google Drive folder ID for invoice images
GDRIVE_FOLDER_ID=your_gdrive_folder_id_here

# Application Settings
APP_TITLE=Construction Cash Tracker
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# Default admin (owner) credentials — set on first run
ADMIN_MOBILE=9999999999
ADMIN_NAME=Owner
